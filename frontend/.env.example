# Application
NEXT_PUBLIC_APP_NAME=e-Kinerja Terpadu
NEXT_PUBLIC_APP_DESCRIPTION=Sistem Pengumpulan, Pengelolaan, Monitoring, Evaluasi, dan Pelaporan Data Manajemen Kinerja Pemerintah Terpadu
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_VERSION=1.0.0

# API
NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXT_PUBLIC_API_TIMEOUT=30000

# Authentication
NEXT_PUBLIC_AUTH_STORAGE=localStorage
# NEXT_PUBLIC_AUTH_STORAGE=httpOnly (recommended for production)

# Features
NEXT_PUBLIC_ENABLE_DARK_MODE=true
NEXT_PUBLIC_ENABLE_AI_FEATURES=true
NEXT_PUBLIC_ENABLE_NOTIFICATIONS=true
NEXT_PUBLIC_ENABLE_EXPORT=true

# Analytics
NEXT_PUBLIC_GA_TRACKING_ID=
NEXT_PUBLIC_SENTRY_DSN=

# Environment
NODE_ENV=development
